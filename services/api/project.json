{
  "name": "service:api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "services/api",
  "sourceRoot": "services/api/cmd/api",
  "tags": ["type:app", "language:go", "type:service"],
  "targets": {
    "tidy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "go mod tidy"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "golangci-lint run ./..."
        ],
        "parallel": false
      }
    },
    "build": {
      "executor": "@naxodev/gonx:build",
      "cache": true,
      "inputs": ["{projectRoot}/go.mod", "{projectRoot}/go.sum", "{projectRoot}/**/*.{go,json,sql}"],
      "options": {
        "main": "cmd/api/main.go",
        "flags": [
          "-ldflags=\"-X main.CommitHash={args.commit} -X main.Tag={args.tag} -s -w\""
        ],
        "args": ["--commit=local", "--tag=latest"],
        "env": {
          "CGO_ENABLED": "0",
          "GOOS": "linux",
          "GOARCH": "amd64"
        },
        "outputPath": "{projectRoot}/dist/"
      },
      "outputs": ["{options.outputPath}"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "air -c .air.toml",
        "cwd": "{projectRoot}"
      }
    },
    "test": {
      "executor": "@naxodev/gonx:test"
    },
    "race": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go test -race -count=1 ./...",
        "cwd": "{projectRoot}"
      }
    },
    "cover": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "go test ./... -coverpkg=./internal/...,./cmd/gateway -coverprofile=cover.out",
          "go tool cover -func=cover.out | tail -1",
          "go tool cover -html=cover.out"
        ],
        "cwd": "{projectRoot}"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "docker buildx build --platform linux/amd64 --tag {args.registry}/llm-gateway-api:{args.tag} --push --build-arg GIT_COMMIT={args.commit} --build-arg GIT_TAG={args.tag} --file services/api/Dockerfile ."
      }
    }
  }
}
